stats  end_stats=[] for c in range(9,18):     vals=[]; bad=[]; errors=0; none=0; text_empty=0     for r in range(5,e.max_row+1):         v=e.cell(r,c).value         if v is None: none+=1; continue         if isinstance(v,str) and v=='': text_empty+=1; continue         if isinstance(v,str) and v.startswith('#'):             errors+=1; bad.append({'row':r,'grade':e.cell(r,2).value,'value':v}); continue         try:             vals.append(float(v))         except Exception:             bad.append({'row':r,'grade':e.cell(r,2).value,'value':v})     end_stats.append({'col':get_column_letter(c),'field':e.cell(2,c).value,'numeric_count':len(vals),'errors':errors,'blank_none':none,'blank_string':text_empty,'min':min(vals) if vals else None,'max':max(vals) if vals else None,'bad_sample':bad[:10]}) report['endpoint_stats'] = end_stats  # Price date order and material mapping with merged inherited element names p=wbv['合金价格'] current_element=None; materials=[] for r in range(3,p.max_row+1):     if p.cell(r,1).value not in (None,''):         current_element=p.cell(r,1).value     materials.append({'row':r,'element_group':current_element,'raw_element':p.cell(r,1).value,'material':p.cell(r,2).value,'base_price':p.cell(r,3).value,'last_price':p.cell(r,p.max_column).value}) report['price_materials_inherited'] = materials  # Raw XML checks for cells where artifact-tool showed 35 but openpyxl sees empty string raw_cells = ['O7','P7','R7','S7','W7','X7','Y7','Z7','Z5'] # map sheet names to worksheet xml via workbook rels with zipfile.ZipFile(path) as z:     wbxml = ET.fromstring(z.read('xl/workbook.xml'))     ns={'m':'[REDACTED_URL]','r':'[REDACTED_URL]'}     rels = ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))     rmap={rel.attrib['Id']: rel.attrib['Target'] for rel in rels}     sheet_paths={s.attrib['name']:'xl/'+rmap[s.attrib['{[REDACTED_URL]']].lstrip('/') for s in wbxml.findall('m:sheets/m:sheet',ns)}     sx=ET.fromstring(z.read(sheet_paths['目标成分']))     raw={}     for c in sx.findall('.//m:c',ns):         ref=c.attrib.get('r')         if ref in raw_cells:             raw[ref]=ET.tostring(c, encoding='unicode')     report['raw_xml_target_cells'] = raw  print(json.dumps(report, ensure_ascii=False, indent=2, default=str)) '@ \\| & 'C:\Users\ZDxia\.cache\codex-runtimes\codex-primary-runtime\dependencies\python\python.exe' -：结果待确认
