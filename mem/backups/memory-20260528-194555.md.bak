- @' import json, zipfile, re from collections import defaultdict, Counter from xml.etree import ElementTree as ET import openpyxl from openpyxl.utils import get_column_letter path = r'D:\Nercar\YongFeng\materials\alloy_cost_calculation\cites\合金基础信息表.xlsx' wb = openpyxl.load_workbook(path, data_only=False, read_only=False) wbv = openpyxl.load_workbook(path, data_only=True, read_only=False)  report = {} report['workbook'] = {     'sheets': [{'name': ws.title, 'state': ws.sheet_state, 'dimension': ws.calculate_dimension()} for ws in wb.worksheets],     'defined_names': [str(n) for n in wb.defined_names.values()], } for ws in wb.worksheets:     hidden_rows = [i for i,d in ws.row_dimensions.items() if d.hidden]     hidden_cols = [k for k,d in ws.column_dimensions.items() if d.hidden]     comments=[]     validations=[]     hyperlinks=[]     for row in ws.iter_rows():         for c in row:             if c.comment:                 comments.append({'cell': c.coordinate, 'text': c.comment.text})             if c.hyperlink:                 hyperlinks.append({'cell': c.coordinate, 'target': c.hyperlink.target})     try:         validations = [str(dv) for dv in ws.data_validations.dataValidation]     except Exception:         validations = []     report[ws.title] = {         'hidden_rows': hidden_rows[:30],         'hidden_cols': hidden_cols,         'comments': comments[:30],         'hyperlinks': hyperlinks[:30],         'data_validations_count': len(validations),         'data_validations_sample': validations[:10],         'auto_filter': str(ws.auto_filter.ref) if ws.auto_filter and ws.auto_filter.ref else None,     }  # Compare target and endpoint row identity t = wbv['目标成分']; e = wbv['终点成分与元素回收率'] key_cols_target = [2,3,4,5,6,7,8] key_cols_end = [2,3,4,5,6,7,8] def norm(v):     if isinstance(v, str): return v.strip().replace('\n','')     return v mismatches=[] for rt, re_ in zip(range(5, t.max_row+1), range(5, e.max_row+1)):     kt = tuple(norm(t.cell(rt,c).value) for c in key_cols_target)     ke = tuple(norm(e.cell(re_,c).value) for c in key_cols_end)     if any(x not in (None,'') for x in kt) or any(x not in (None,'') for x in ke):         if kt != ke:             mismatches.append({'target_row': rt, 'endpoint_row': re_, 'target_key': kt, 'endpoint_key': ke}) report['cross_sheet_compare'] = {     'rowwise_key_mismatches_count': len(mismatches),     'rowwise_key_mismatches_sample': mismatches[:20], } # Build key sets ignoring sequence? business key grade+category+thick+steelmaking for sheet_name, ws in [('target', t), ('endpoint', e)]:     keys = defaultdict(list)     for r in range(5, ws.max_row+1):         if ws.cell(r,2).value in (None,''):             continue         key = tuple(norm(ws.cell(r,c).value) for c in [2,3,4,5,6])         keys[key].append(r)     report[f'{sheet_name}_keys'] = {         'valid_key_count': len(keys),         'duplicate_count': sum(1 for v in keys.values() if len(v)>1),         'duplicates_sample': [{'key': k, 'rows': v} for k,v in keys.items() if len(v)>1][:20]     }  # Element statistics in target and endpoint elements_target = {get_column_letter(c): t.cell(3,c).value for c in range(9,27)} stats=[] for c in range(9,27):     vals=[]; text_empty=0; none=0; bad=[]     for r in range(5, t.max_row+1):         v=t.cell(r,c).value         if v is None: none += 1; continue         if isinstance(v,str) and v=='': text_empty += 1; continue         try:             fv=float(v)             vals.append(fv)             if fv < 0 or fv > 10:                 bad.append({'row':r,'grade':t.cell(r,2).value,'value':fv})         except Exception:             bad.append({'row':r,'grade':t.cell(r,2).value,'value':v})     stats.append({'col':get_column_letter(c),'element':t.cell(3,c).value,'numeric_count':len(vals),'blank_none':none,'blank_string':text_empty,'min':min(vals) if vals else None,'max':max(vals) if vals else None,'gt10_count':sum(1 for x in vals if x>10),'gt10_sample':bad[:10]}) report['target_element_stats'] = stats  end_stats=[] for c in range(9,18):     vals=[]; bad=[]; errors=0; none=0; text_empty=0     for r in range(5,e.max_row+1):         v=e.cell(r,c).value         if v is None: none+=1; continue         if isinstance(v,str) and v=='': text_empty+=1; continue         if isinstance(v,str) and v.startswith('#'):             errors+=1; bad.append({'row':r,'grade':e.cell(r,2).value,'value':v}); continue         try:             vals.append(float(v))         except Exception:             bad.append({'row':r,'grade':e.cell(r,2).value,'value':v})     end_stats.append({'col':get_column_letter(c),'field':e.cell(2,c).value,'numeric_count':len(vals),'errors':errors,'blank_none':none,'blank_string':text_empty,'min':min(vals) if vals else None,'max':max(vals) if vals else None,'bad_sample':bad[:10]}) report['endpoint_stats'] = end_stats  # Price date order and material mapping with merged inherited element names p=wbv['合金价格'] current_element=None; materials=[] for r in range(3,p.max_row+1):     if p.cell(r,1).value not in (None,''):         current_element=p.cell(r,1).value     materials.append({'row':r,'element_group':current_element,'raw_element':p.cell(r,1).value,'material':p.cell(r,2).value,'base_price':p.cell(r,3).value,'last_price':p.cell(r,p.max_column).value}) report['price_materials_inherited'] = materials  # Raw XML checks for cells where artifact-tool showed 35 but openpyxl sees empty string raw_cells = ['O7','P7','R7','S7','W7','X7','Y7','Z7','Z5'] # map sheet names to worksheet xml via workbook rels with zipfile.ZipFile(path) as z:     wbxml = ET.fromstring(z.read('xl/workbook.xml'))     ns={'m':'[REDACTED_URL]','r':'[REDACTED_URL]'}     rels = ET.fromstring(z.read('xl/_rels/workbook.xml.rels'))     rmap={rel.attrib['Id']: rel.attrib['Target'] for rel in rels}     sheet_paths={s.attrib['name']:'xl/'+rmap[s.attrib['{[REDACTED_URL]']].lstrip('/') for s in wbxml.findall('m:sheets/m:sheet',ns)}     sx=ET.fromstring(z.read(sheet_paths['目标成分']))     raw={}     for c in sx.findall('.//m:c',ns):         ref=c.attrib.get('r')         if ref in raw_cells:             raw[ref]=ET.tostring(c, encoding='unicode')     report['raw_xml_target_cells'] = raw  print(json.dumps(report, ensure_ascii=False, indent=2, default=str)) '@ \\| & 'C:\Users\ZDxia\.cache\codex-runtimes\codex-primary-runtime\dependencies\python\python.exe' -：结果待确认
