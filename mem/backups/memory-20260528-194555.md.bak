req = (             f"GET {path} HTTP/1.1\r\n"             f"Host: {host}:{port}\r\n"             "Upgrade: websocket\r\n"             "Connection: Upgrade\r\n"             f"Sec-WebSocket-Key: {key}\r\n"             "Sec-WebSocket-Version: 13\r\n\r\n"         ).encode("ascii")         s.sendall(req)         data = b""         while b"\r\n\r\n" not in data:             data += s.recv(4096)         if b" 101 " not in data.split(b"\r\n", 1)[0]:             raise RuntimeError(data[:500])         self.sock = s      def _send_text(self, text):         payload = text.encode("utf-8")         header = bytearray([0x81])         n = len(payload)         if n < 126:             header.append(0x80 \| n)         elif n < 65536:             header.append(0x80 \| 126)             header.extend(struct.pack("!H", n))         else:             header.append(0x80 \| 127)             header.extend(struct.pack("!Q", n))         mask = os.urandom(4)         masked = bytes(b ^ mask[i % 4] for i, b in enumerate(payload))         self.sock.sendall(bytes(header) + mask + masked)      def _recvn(self, n):         chunks = []         remaining = n         while remaining:             chunk = self.sock.recv(remaining)             if not chunk:                 raise EOFError("websocket closed")             chunks.append(chunk)             remaining -= len(chunk)         return b"".join(chunks)      def _recv_text(self):         while True:             first, second = self._recvn(2)             opcode = first & 0x0F             masked = bool(second & 0x80)             length = second & 0x7F             if length == 126:                 length = struct.unpack("!H", self._recvn(2))[0]             elif length == 127:                 length = struct.unpack("!Q", self._recvn(8))[0]             mask = self._recvn(4) if masked else b""             payload = self._recvn(length) if length else b""             if masked:                 payload = bytes(b ^ mask[i % 4] for i, b in enumerate(payload))             if opcode == 1:                 return payload.decode("utf-8")             if opcode == 8:                 raise EOFError("websocket close frame")             if opcode == 9:                 # Pong.                 self.sock.sendall(b"\x8a\x00")      def cmd(self, method, params=None, timeout=10):         self.id += 1         msg_id = self.id         self._send_text(json.dumps({"id": msg_id, "method": method, "params": params or {}}, ensure_ascii=False))         deadline = time.time() + timeout         while time.time() < deadline:             msg = json.loads(self._recv_text())             if "id" in msg and msg["id"] == msg_id:                 if "error" in msg:                     raise RuntimeError(f"{method}: {msg['error']}")                 return msg.get("result", {})             self.events.append(msg)         raise TimeoutError(method)      def eval(self, expression, timeout=10):         result = self.cmd("Runtime.evaluate", {             "expression": expression,             "awaitPromise": True,             "returnByValue": True,         }, timeout=timeout)         if "exceptionDetails" in result:             raise RuntimeError(result["exceptionDetails"])         return result.get("result", {}).get("value")   def get_json(url, timeout=10):     with urllib.request.urlopen(url, timeout=timeout) as r:         return json.loads(r.read().decode("utf-8"))  with tempfile.TemporaryDirectory(prefix="alloy-cdp-") as profile:     proc = subprocess.Popen([         CHROME,         "--headless=new",         "--disable-gpu",         "--no-first-run",         "--no-default-browser-check",         "--remote-allow-origins=*",         f"--remote-debugging-port={PORT}",         f"--user-data-dir={profile}",         URL,     ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)     try:         version = None         for _ in range(80):             try:                 version = get_json(f"[REDACTED_URL]", timeout=1)                 break             except Exception:                 time.sleep(0.1)         if not version:             raise RuntimeError("Chrome remote debugging did not start")         pages = get_json(f"[REDACTED_URL]", timeout=3)         page = next((p for p in pages if p.get("type") == "page"), pages[0])         cdp = CDP(page["webSocketDebuggerUrl"])         for method in ["Runtime.enable", "Log.enable", "Page.enable", "Network.enable", "DOM.enable"]:             cdp.cmd(method)         for _ in range(100):             if cdp.eval("document.readyState") == "complete":                 break             time.sleep(0.1)         time.sleep(0.5)         initial = cdp.eval("({ title: document.title, validate: typeof window.validateBatchTemplate, run: typeof window.runBatchOptimize, exportFn: typeof window.exportBatchResult, duplicate: document.body.innerText.includes('下载批量模板'), downloadLinks: document.querySelectorAll('a[href=\"/api/template/download\"]').length, batchOpen: document.querySelector('.batch-panel')?.open \|\| false, script: document.querySelector('script[src^=\"ui.js\"]')?.getAttribute('src') })")         cdp.eval("document.querySelector('.batch-panel summary').click()")         doc = cdp.cmd("DOM.getDocument", {"depth": -1, "pierce": True})         node = cdp.cmd("DOM.querySelector", {"nodeId": doc["root"]["nodeId"], "selector": "#batchFile"})["nodeId"]         if not node:             raise RuntimeError("#batchFile not found")         cdp.cmd("DOM.setFileInputFiles", {"nodeId": node, "files": [FILE]})         cdp.eval("document.getElementById('batchFile').dispatchEvent(new Event('change', { bubbles: true }))")         after_file = cdp.eval("({label: document.getElementById('batchFileLabel').textContent, status: document.getElementById('batchStatus').textContent, validateType: typeof window.validateBatchTemplate})")         cdp.eval("document.getElementById('validateBatchButton').click()")         precheck = None         for _ in range(200):             state = cdp.eval("({status: document.getElementById('batchStatus').textContent, runDisabled: document.getElementById('runBatchButton').disabled, exportDisabled: document.getElementById('exportBatchButton').disabled})")             if (not state["runDisabled"]) or "预检失败" in state["status"] or "接口失败" in state["status"]:                 precheck = state                 break             time.sleep(0.1)         if precheck is None:             precheck = state         if precheck["runDisabled"]:             raise RuntimeError("Precheck did not enable batch run: " + json.dumps(precheck, ensure_ascii=False))         cdp.eval("document.getElementById('runBatchButton').click()")         batch = None         for _ in range(300):             state = cdp.eval("({status: document.getElementById('batchStatus').textContent, runDisabled: document.getElementById('runBatchButton').disabled, exportDisabled: document.getElementById('exportBatchButton').disabled, preview: document.getElementById('batchPreview').innerText})")             if "批量计算完成" in state["status"] or "批量计算失败" in state["status"]:                 batch = state                 break             time.sleep(0.1)         if batch is None:             batch = state         errors = []         responses = []         for event in cdp.events:             method = event.get("method")             params = event.get("params", {})             if method == "Runtime.exceptionThrown":                 errors.append({"method": method, "text": params.get("exceptionDetails", {}).get("text")})             if method == "Log.entryAdded" and params.get("entry", {}).get("level") in {"error", "warning"}:                 errors.append({"method": method, "entry": params.get("entry")})             if method == "Runtime.consoleAPICalled" and params.get("type") in {"error", "warning"}:                 errors.append({"method": method, "type": params.get("type")})             if method == "Network.responseReceived":                 resp = params.get("response", {})                 url = resp.get("url", "")                 if "api/template/validate" in url or "api/batch-optimize" in url or url.endswith("/ui.js?v=20260528-batch-upload") or url.endswith("/"):                     responses.append({"url": url, "status": resp.get("status")})         print(json.dumps({             "initial": initial,             "afterFile": after_file,             "precheck": precheck,             "batch": batch,             "responses": responses,             "consoleProblems": errors,         }, ensure_ascii=False, indent=2))     finally:         proc.terminate()         try:             proc.wait(timeout=5)         except subprocess.TimeoutExpired:             proc.kill() '@ \| .venv-win\Scripts\python.exe -：结果待确认；git diff --check -- prototype.html tests\ui_static.test.js ui.js：结果待确认

