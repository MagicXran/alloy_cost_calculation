tById('batchStatus').textContent, runDisabled: document.getElementById('runBatchButton').disabled, exportDisabled: document.getElementById('exportBatchButton').disabled})")             if (not state["runDisabled"]) or "预检失败" in state["status"] or "接口失败" in state["status"]:                 precheck = state                 break             time.sleep(0.1)         if precheck is None:             precheck = state         if precheck["runDisabled"]:             raise RuntimeError("Precheck did not enable batch run: " + json.dumps(precheck, ensure_ascii=False))         cdp.eval("document.getElementById('runBatchButton').click()")         batch = None         for _ in range(300):             state = cdp.eval("({status: document.getElementById('batchStatus').textContent, runDisabled: document.getElementById('runBatchButton').disabled, exportDisabled: document.getElementById('exportBatchButton').disabled, preview: document.getElementById('batchPreview').innerText})")             if "批量计算完成" in state["status"] or "批量计算失败" in state["status"]:                 batch = state                 break             time.sleep(0.1)         if batch is None:             batch = state         errors = []         responses = []         for event in cdp.events:             method = event.get("method")             params = event.get("params", {})             if method == "Runtime.exceptionThrown":                 errors.append({"method": method, "text": params.get("exceptionDetails", {}).get("text")})             if method == "Log.entryAdded" and params.get("entry", {}).get("level") in {"error", "warning"}:                 errors.append({"method": method, "entry": params.get("entry")})             if method == "Runtime.consoleAPICalled" and params.get("type") in {"error", "warning"}:                 errors.append({"method": method, "type": params.get("type")})             if method == "Network.responseReceived":                 resp = params.get("response", {})                 url = resp.get("url", "")                 if "api/template/validate" in url or "api/batch-optimize" in url or url.endswith("/ui.js?v=20260528-batch-upload") or url.endswith("/"):                     responses.append({"url": url, "status": resp.get("status")})         print(json.dumps({             "initial": initial,             "afterFile": after_file,             "precheck": precheck,             "batch": batch,             "responses": responses,             "consoleProblems": errors,         }, ensure_ascii=False, indent=2))     finally:         proc.terminate()         try:             proc.wait(timeout=5)         except subprocess.TimeoutExpired:             proc.kill() '@ \| .venv-win\Scripts\python.exe -：结果待确认；git diff --check -- prototype.html tests\ui_static.test.js ui.js：结果待确认

